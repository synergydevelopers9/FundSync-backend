// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  // To switch to PostgreSQL, change provider to "postgresql" and update the env URL
  provider = "sqlite"
  url      = "file:./dev.db"
}

model User {
  id           String    @id @default(uuid())
  email        String    @unique
  passwordHash String
  role         String    // "ADMIN" | "MEMBER"
  isActive     Boolean   @default(true)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  deletedAt    DateTime? // Soft delete support

  admin   Admin?
  member  Member?
  tokens  PasswordResetToken[]
  logs    AuditLog[]
  notifications Notification[]
}

model Admin {
  id        String    @id @default(uuid())
  userId    String    @unique
  username  String    @unique
  name      String
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Member {
  id           String    @id @default(uuid())
  userId       String    @unique
  memberId     String    @unique // Unique incremental ID e.g., M000001
  fullName     String
  fatherName   String?
  mobile       String    @unique
  dateOfBirth  String
  gender       String
  address      String
  city         String
  state        String
  pinCode      String
  govId        String?
  profilePhoto String?
  planId       String?
  status       String    @default("ACTIVE") // "ACTIVE" | "INACTIVE" | "DEACTIVATED"
  nextDueDate  DateTime?
  amountPaid   Float     @default(0)
  pendingAmount Float    @default(0)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  deletedAt    DateTime?

  user          User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  plan          Plan?          @relation(fields: [planId], references: [id])
  payments      Payment[]
  subscriptions Subscription[]
  tickets       SupportTicket[]
}

model Plan {
  id           String    @id @default(uuid())
  name         String
  monthlyAmount Float
  description  String
  renewalCycle String    @default("MONTHLY") // "MONTHLY" | "QUARTERLY" | "YEARLY"
  startDate    DateTime  @default(now())
  status       String    @default("ACTIVE") // "ACTIVE" | "ARCHIVED" | "DEACTIVATED"
  benefits     String    // Stored as JSON string or comma-separated
  colorLabel   String    @default("brand") // CSS theme color: brand, emerald, violet, amber, rose
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  deletedAt    DateTime?

  members       Member[]
  subscriptions Subscription[]
}

model Payment {
  id             String    @id @default(uuid())
  memberId       String
  amount         Float
  date           DateTime  @default(now())
  transactionId  String    @unique
  gatewayResponse String?   // JSON response from gateway as string
  paymentMethod  String    // "UPI" | "CARD" | "NET_BANKING" | "MOCK"
  receiptUrl     String?
  status         String    @default("PENDING") // "PENDING" | "SUCCESS" | "FAILED" | "REFUNDED" | "CANCELLED"
  invoiceNumber  String    @unique
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  deletedAt      DateTime?

  member  Member   @relation(fields: [memberId], references: [id])
  receipt Receipt?
}

model Subscription {
  id         String    @id @default(uuid())
  memberId   String
  planId     String
  status     String    @default("ACTIVE") // "ACTIVE" | "EXPIRED" | "CANCELLED"
  startDate  DateTime  @default(now())
  endDate    DateTime
  autoRenew  Boolean   @default(true)
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  deletedAt  DateTime?

  member Member @relation(fields: [memberId], references: [id])
  plan   Plan   @relation(fields: [planId], references: [id])
}

model Notification {
  id        String   @id @default(uuid())
  userId    String
  title     String
  message   String
  type      String   @default("INFO") // "INFO" | "PAYMENT" | "DUE" | "SYSTEM"
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Announcement {
  id         String   @id @default(uuid())
  title      String
  content    String
  targetRole String   @default("ALL") // "ALL" | "MEMBER" | "ADMIN"
  isPinned   Boolean  @default(false)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model AuditLog {
  id        String   @id @default(uuid())
  userId    String?
  action    String
  details   String
  ipAddress String?
  userAgent String?
  createdAt DateTime @default(now())

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)
}

model PasswordResetToken {
  id        String   @id @default(uuid())
  userId    String
  token     String   @unique // OTP Code
  expiresAt DateTime
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Receipt {
  id            String   @id @default(uuid())
  paymentId     String   @unique
  receiptNumber String   @unique
  pdfPath       String
  qrCodeData    String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  payment Payment @relation(fields: [paymentId], references: [id], onDelete: Cascade)
}

model Report {
  id           String   @id @default(uuid())
  name         String
  type         String   // "REVENUE" | "MEMBER" | "PLAN" | "PENDING"
  format       String   // "CSV" | "EXCEL" | "PDF"
  filterParams String?  // JSON query parameters as string
  filePath     String
  generatedBy  String
  createdAt    DateTime @default(now())
}

model SupportTicket {
  id          String    @id @default(uuid())
  memberId    String
  subject     String
  description String
  status      String    @default("OPEN") // "OPEN" | "IN_PROGRESS" | "RESOLVED" | "CLOSED"
  priority    String    @default("MEDIUM") // "LOW" | "MEDIUM" | "HIGH"
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  deletedAt   DateTime?

  member Member @relation(fields: [memberId], references: [id], onDelete: Cascade)
}
